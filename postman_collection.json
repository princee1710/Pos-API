{
  "info": {
    "name": "JAWAIN API",
    "description": "Koleksi Postman untuk menguji API backend JAWAIN (Cloudflare Pages Functions). Ganti variable base_url sesuai kebutuhan (localhost saat dev, atau domain Cloudflare setelah deploy).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8788",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Ambil Daftar Menu",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/menu",
          "host": ["{{base_url}}"],
          "path": ["api", "menu"]
        }
      },
      "response": []
    },
    {
      "name": "Kirim Pesanan",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer\": {\n    \"nama\": \"Rangga\",\n    \"telepon\": \"08123456789\",\n    \"catatan\": \"Gula sedikit ya\"\n  },\n  \"items\": [\n    { \"id\": \"1\", \"name\": \"Kopi Susu Gula Aren\", \"qty\": 2, \"price\": 22000 },\n    { \"id\": \"7\", \"name\": \"Roti Bakar Cokelat Keju\", \"qty\": 1, \"price\": 17000 }\n  ],\n  \"total\": 61000\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/order",
          "host": ["{{base_url}}"],
          "path": ["api", "order"]
        }
      },
      "response": []
    },
    {
      "name": "Kirim Pesanan (Data Tidak Lengkap - contoh error)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer\": {\n    \"nama\": \"\"\n  },\n  \"items\": []\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/order",
          "host": ["{{base_url}}"],
          "path": ["api", "order"]
        }
      },
      "response": []
    }
  ]
}
